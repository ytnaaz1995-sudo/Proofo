// FILE: src/utils/storage.js
/**
 * Simple encrypted localStorage wrapper
 */
const SECRET = 'proofo_secret_key'

const encode = (data) => {
  return btoa(JSON.stringify(data) + SECRET)
}

const decode = (data) => {
  try {
    const str = atob(data).replace(SECRET, '')
    return JSON.parse(str)
  } catch {
    return null
  }
}

export const storage = {
  set(key, value) {
    localStorage.setItem(key, encode(value))
  },
  get(key) {
    const data = localStorage.getItem(key)
    return data ? decode(data) : null
  },
  remove(key) {
    localStorage.removeItem(key)
  }
}
// END OF FILE

